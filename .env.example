# Flowly integration config
#
# Frontend (Vite) — choose mock (default) or live mode:
VITE_FLOWLY_MODE=mock
# VITE_FLOWLY_MODE=live
VITE_FLOWLY_API_BASE=/api/flowly

# Backend (server only — NEVER exposed to the frontend):
# Leave blank to run the backend in deterministic stub mode.
WATSONX_ORCHESTRATE_URL=
WATSONX_ORCHESTRATE_API_KEY=
WATSONX_ORCHESTRATE_AGENT_ID=
PORT=8787
